# Keep the build context minimal and avoid leaking secrets/cruft into images
# (supports ADR-0002 supply-chain hygiene). Paths are relative to the build
# context (the docker/ directory).
.git
.gitignore
**/.env
**/.env.*
**/*.pem
**/*.key
**/*.crt
**/id_rsa*
**/secrets*
# Build/output artifacts that should never enter an image:
node_modules
target
dist
build
*.log
# Docs/markdown are not needed at build time:
*.md
